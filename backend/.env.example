# 复制本文件为 .env 后填写（与项目根目录 .env 二选一即可，后端会同时读取）
# 后端启动目录为 backend/ 时优先读 backend/.env，其次读 ../.env

# 高德
AMAP_WEB_SERVICE_KEY=
AMAP_WEB_KEY=

# 七牛
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=
QINIU_ZONE=z2

# 视觉 AI（SiliconFlow）
VISION_API_KEY=
VISION_BASE_URL=https://api.siliconflow.cn/v1
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# DeepSeek 文案
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 其余配置见项目根目录 .env.example
# 多个前端域名用英文逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:5175
