# 应用配置
NODE_ENV=development
BACKEND_PORT=3000
PC_PORT=8080
H5_PORT=8081

# PostgreSQL（本地用拆分字段；云端可用 DATABASE_URL）
POSTGRES_USER=inspection
POSTGRES_PASSWORD=inspection123
POSTGRES_DB=inspection_db
POSTGRES_PORT=5432
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=inspection
DB_PASSWORD=inspection123
DB_DATABASE=inspection_db
# 云端 Postgres（Render Blueprint 会自动注入 DATABASE_URL，一般不用手填）
# 若改用 Neon/Supabase，再手动粘贴 URI
DATABASE_URL=
# 首次上线建表+种子设 true；稳定后务必改 false
DB_SYNC=false
# Render / Neon / Supabase 托管库一般为 true
DB_SSL=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=inspection
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# JWT
JWT_ACCESS_SECRET=inspection_access_secret_change_me_in_prod
JWT_REFRESH_SECRET=inspection_refresh_secret_change_me_in_prod
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# 默认超级管理员（首次启动种子数据）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_REAL_NAME=超级管理员
ADMIN_PHONE=13800000000

# 高德地图（Web 服务 Key，地理编码 / 逆地理）
AMAP_WEB_SERVICE_KEY=
AMAP_WEB_KEY=

# 七牛云（配置后优先于 MinIO；密钥勿带 VITE_）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=http://your-bucket.hn-bkt.clouddn.com
QINIU_ZONE=z2
QINIU_UPLOAD_URL=https://upload-z2.qiniup.com

# 巡检现场围栏（默认 500 米；GPS 精度差于 200 米时要求重新定位）
INSPECTION_RADIUS_METERS=500
INSPECTION_MAX_GPS_ACCURACY=200

# SiliconFlow 视觉对比（巡检 AI）
VISION_API_KEY=
VISION_BASE_URL=https://api.siliconflow.cn/v1
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# DeepSeek（AI reason 文案润色，服务端）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Supabase（BaaS 后端）
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# 前端 / Vercel
VITE_SUPABASE_ANON_KEY=
# Edge Function 网关（部署 api 函数后）
# VITE_API_BASE=https://YOUR_PROJECT.supabase.co/functions/v1/api


# PC / H5 前端（Vercel 构建时配置）
VITE_H5_URL=http://localhost:5175/m/login
# 线上 API 根路径，例如 https://xxx.onrender.com/api
VITE_API_BASE=
VITE_AMAP_KEY=
